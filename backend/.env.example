# Local debug environment for deploy/docker-compose.debug.yml

# Postgres connection used by the backend container.
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOST=postgres_db
DB_PORT=5432
DB_NAME=postgres

# Session middleware secret for local development.
SESSION_SECRET=change-me-local-dev

# SMTP settings used by the mail diagnostic endpoints.
SENDER=test@example.com
MAIL_PW=test-mail-password
SMTP_RELAY=smtp.example.com

# Chat model defaults used by the backend service.
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional local overrides.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
GOOGLE_API_KEY=
